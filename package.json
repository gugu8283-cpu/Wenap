{
  "name": "wenap",
  "private": true,
  "version": "1.0.0",
  "description": "Wenap — 联网投研报告、六维评分与可视化（可单容器上架）",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "server": "node server.cjs",
    "dev:full": "node scripts/dev-full.cjs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server.cjs",
    "start:prod": "npm run build && node -e \"process.env.NODE_ENV='production';process.env.SERVE_DIST='1';require('child_process').spawnSync('node',['server.cjs'],{stdio:'inherit',env:process.env})\"",
    "setup": "node scripts/setup-env.cjs",
    "seed": "node scripts/seed-demo.cjs",
    "seed:reset": "node scripts/seed-demo.cjs --reset-demo",
    "clear:data": "node scripts/clear-data.cjs",
    "backup:data": "node scripts/backup-data.cjs",
    "smoke": "node scripts/smoke-api.cjs",
    "prepare:local": "npm run setup && npm run seed && npm run smoke",
    "admin:hint": "node scripts/print-admin-hint.cjs",
    "rebuild:native": "npm rebuild better-sqlite3",
    "postinstall": "npm rebuild better-sqlite3",
    "create-test-accounts": "node scripts/createTestAccounts.cjs"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "disposable-email-domains": "^1.0.62",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.12"
  }
}
