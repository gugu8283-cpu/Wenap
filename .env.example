# 复制为 .env 后填写（切勿把真实 .env 提交到仓库）
OPENROUTER_API_KEY=
# 主模型 slug（Free/Pro 默认 google/gemini-2.5-flash-lite）
# 凡 google/gemini-* 在设 GEMINI_API_KEY 后走 Google Gemini API，不经 OpenRouter
# OPENROUTER_MAIN_MODEL=google/gemini-2.5-flash-lite
# 行情主源（Phase A）：Marketstack Basic（商用）
MARKETSTACK_API_KEY=
# 行情来源：marketstack | alphavantage（默认 alphavantage；切换后建议 marketstack）
# MARKET_DATA_PROVIDER=marketstack
# 过渡期回退（可保留）
ALPHA_VANTAGE_API_KEY=
# Redis 缓存（Phase A；默认 15 分钟）
# REDIS_URL=redis://redis:6379

# Alpha Vantage 同一标的缓存毫秒数（默认 600000=10 分钟；0=关闭）。减少重复请求与 1.2s 间隔，降本且对分钟级行情影响小
# ALPHA_VANTAGE_CACHE_MS=600000

# OpenRouter 单次补全 max_tokens 上限（默认主 4000、政策法规补刀 1024）
# OPENROUTER_MAX_OUTPUT_TOKENS_MAIN=4000
# OPENROUTER_MAX_OUTPUT_TOKENS_LEADER=1024

# Pro+ Pass1 / 批评家：仅 Anthropic Haiku 走 OpenRouter（默认 anthropic/claude-haiku-4-5）
# OPENROUTER_PRO_PLUS_PASS1_MODEL=anthropic/claude-haiku-4-5
# OPENROUTER_CRITIQUE_MODEL=anthropic/claude-haiku-4-5
# Pro+ Pass2 等 Gemini slug → Google API（默认 google/gemini-2.5-flash-lite）
# OPENROUTER_PRO_PLUS_PASS2_MODEL=google/gemini-2.5-flash-lite
# 个股政策法规维补刀（Gemini slug → Google API；默认 google/gemini-2.5-flash）
# OPENROUTER_POLICY_MODEL=google/gemini-2.5-flash

# 第六维「政策法规」：默认由主模型一次输出；主模型该维不达标时用同档主模型补刀（设 0 关闭）
# OPENROUTER_POLICY_FALLBACK=1
# 补刀默认不二次联网（env 名仍为 LEADER）；需更强核验时开启
# OPENROUTER_LEADER_USE_WEB=1
# OPENROUTER_LEADER_RETRY=1

# 服务端口（默认 3002）
PORT=3002

# 生产托管前端：与 npm run build 生成的 dist/ 一起使用
# Windows（PowerShell）: $env:NODE_ENV="production"; node server.cjs
# Linux/macOS: NODE_ENV=production node server.cjs
# NODE_ENV=production

# 仅托管静态站、不强制 NODE_ENV 时可用：
# SERVE_DIST=1

# 反向代理后需正确识别 HTTPS / 客户端 IP 时：
# TRUST_PROXY=1

# 前后端分离部署时，允许的浏览器来源（逗号分隔）；留空则开发态宽松
# CORS_ORIGIN=https://your-frontend.example.com

# 默认免费 5 次/月；试运行不限次：WENAP_FREE_UNLIMITED=1

# 开发跳过免费次数（勿用于生产上架）
# WENAP_SKIP_QUOTA=1

# 账号认证（JWT，生产环境务必更换 JWT_SECRET）
# JWT_SECRET=请设置至少32位随机字符串
# JWT_EXPIRES=7d
# APP_PUBLIC_URL=http://localhost:5173
# 设备指纹限制（默认关闭；设为 1 启用每设备累计 10 次免费分析）
# WENAP_DEVICE_FINGERPRINT=0

# 注册验证 / 找回密码（生产必填其一）
# 方式 A — Resend API（推荐）：https://resend.com → API Keys
# RESEND_API_KEY=re_...
# MAIL_FROM=Wenap <noreply@你的已验证域名>
# 方式 B — SMTP（可用 Resend SMTP：host smtp.resend.com, user resend, pass=API key）
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Wenap <noreply@wenap.app>

# 前端品牌名（可选，用于 PWA / 页面标题覆盖）
# VITE_APP_NAME=Wenap
# VITE_APP_TITLE=Wenap · 投研助理

# 前端构建：若部署在子路径，与 Vite 一致
# VITE_BASE_PATH=/wenap/

# 前端运行时：生产环境也显示「成本与毛利试算」折叠面板（默认关闭）
# VITE_SHOW_ECONOMICS=1

# 管理员与预测追踪（SQLite 默认 data/wenap.db）
# ADMIN_SECRET=请设置至少32位强密码
# 管理后台：日本 PCI 申告用 — IP 白名单（逗号分隔，生产建议必填）
# ADMIN_IP_ALLOWLIST=203.0.113.10
# 第二因子 PIN（与 ADMIN_SECRET 同时提交；请求头 X-Admin-Pin）
# ADMIN_PIN=
# ADMIN_LOCKOUT_MAX=10
# LOGIN_LOCKOUT_MAX=10
# CRON_ENABLED=true
# PREDICTION_VERIFY_DAYS=30
# TENDENCY_THRESHOLD=5
# SQLITE_PATH=./data/wenap.db

# 开发：前端请求 tier 覆盖（pro | pro_plus），优先于 localStorage.wenap_tier
# VITE_DEV_TIER=pro_plus
# 无 VITE_SUBSCRIBE_URL 时允许「解锁查看 / 升级 Pro」写入本地 tier 并重跑分析（需 npm run dev 或设 1）
# VITE_DEV_UNLOCK=1

# 本地一键准备（生成 ADMIN_SECRET、演示数据、冒烟测试）：
# npm run prepare:local

# Docker 生产：
# docker compose up -d --build

# Vultr / VPS（见 docs/DEPLOY-VULTR.md，推荐 docker compose）：
# APP_PUBLIC_URL=https://你的域名  TRUST_PROXY=1  CRON_ENABLED=true

# Render（见 docs/DEPLOY-RENDER.md）：
# SQLITE_PATH=/var/data/wenap.db  APP_PUBLIC_URL=https://wenap.app

# --- Gemini API（XPRIZE 合规；推荐：AI Studio 密钥，无需 Vertex）---
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash-lite
# 政策法规维补刀走 Gemini API（1=默认开启，需 GEMINI_API_KEY）
# GEMINI_POLICY_ENABLED=1
# GEMINI_POLICY_MODEL=gemini-2.5-flash-lite

# --- 可选：Vertex AI（需启用 aiplatform API + GCP_PROJECT_ID；搜不到可跳过）---
# GCP_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=asia-northeast1
# VERTEX_GEMINI_MODEL=gemini-2.5-flash-lite
# VERTEX_POLICY_ENABLED=1
# VERTEX_POLICY_MODEL=gemini-2.5-flash-lite
# GCE 持久数据（见 docs/GCP-全迁方案.md）：
# SQLITE_PATH=/app/data/wenap.db  DATA_DIR=/app/data  TRUST_PROXY=1

# --- Tier models (OpenRouter slugs) ---
# OPENROUTER_MAIN_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_PRO_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_PRO_PLUS_MODEL=openai/gpt-5.4-mini
# Pro+ 每 UTC 月最多分析次数（防刷接口），默认 1000
# WENAP_PRO_PLUS_MONTHLY_CAP=1000
# 付费用户进入“利润保护区”后触发限速与冷却
# WENAP_PRO_MONTHLY_PROFIT_THRESHOLD=500
# WENAP_PRO_PLUS_MONTHLY_PROFIT_THRESHOLD=250
# WENAP_PRO_HOURLY_LIMIT_AFTER_THRESHOLD=40
# WENAP_PRO_PLUS_HOURLY_LIMIT_AFTER_THRESHOLD=25
# WENAP_PAID_COOLDOWN_MINUTES=20
# 同一标的+期限+语言 1 小时内复用缓存报告（0=关闭），默认 3600000 ms
# WENAP_ANALYSIS_CACHE_MS=3600000
# 主分析 OpenRouter 超时（毫秒）；0=不限制。排队等待：0=不限制（默认）
# OPENROUTER_TIMEOUT_MS=0
# WENAP_ANALYSIS_QUEUE_MAX_MS=0

# --- Referral bonus (email verified → both may get Pro in DB; API cost only when they run analyze) ---
# WENAP_REFERRAL_REWARDS=0   # set to 0/false/off to disable granting (no extra OpenRouter from “tier” alone)

# WENAP_CRON_SECRET=at-least-8-chars
# CRON_SERVICE_USER_ID=<existing users.id UUID>
# CRON_AUTO_ANALYSIS=false
